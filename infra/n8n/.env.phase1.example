# Local n8n runtime for the Phase 1 statement ingestion workflow.
DRIVE_FOLDER_ID=replace-with-google-drive-folder-id
STATEMENT_PIPELINE_SHARED_SECRET=replace-with-shared-pipeline-secret
STATEMENT_PARSE_URL=https://project-ref.supabase.co/functions/v1/statement-parse
STATEMENT_INGEST_URL=https://project-ref.supabase.co/functions/v1/statement-ingest
STATEMENT_HOUSEHOLD_ID=11111111-1111-4111-8111-111111111111
STATEMENT_FILE_ROUTING_JSON=[{"fileNamePattern":"hdfc.*regalia.*\\.pdf$","parserProfileName":"hdfc-regalia-gold","bankName":"HDFC Bank","cardName":"Regalia Gold","statementPasswordKey":"cards/hdfc-regalia"}]
STATEMENT_PDF_PASSWORD__CARDS_HDFC_REGALIA=replace-with-the-actual-password
PDF_TEXT_EXTRACT_COMMAND=node /absolute/path/to/repo/infra/n8n/bin/extract-pdf-text.mjs
