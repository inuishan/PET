# Shared function runtime for whatsapp-webhook, whatsapp-parse, whatsapp-ingest, and whatsapp-reply.
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
META_WEBHOOK_VERIFY_TOKEN=replace-with-meta-webhook-verify-token
META_APP_SECRET=replace-with-meta-app-secret
WHATSAPP_INTERNAL_AUTH_TOKEN=replace-with-shared-internal-whatsapp-secret
WHATSAPP_PARSE_FUNCTION_URL=https://project-ref.supabase.co/functions/v1/whatsapp-parse
WHATSAPP_PARSE_TIMEOUT_MS=5000
WHATSAPP_INGEST_FUNCTION_URL=https://project-ref.supabase.co/functions/v1/whatsapp-ingest
WHATSAPP_INGEST_TIMEOUT_MS=5000
WHATSAPP_REPLY_FUNCTION_URL=https://project-ref.supabase.co/functions/v1/whatsapp-reply
WHATSAPP_REPLY_TIMEOUT_MS=5000
WHATSAPP_ACK_ENABLED=false
WHATSAPP_ACK_REPLY_WINDOW_MS=86400000
META_WHATSAPP_ACCESS_TOKEN=replace-with-meta-whatsapp-access-token
META_GRAPH_API_BASE_URL=https://graph.facebook.com/v23.0
# Optional live-validation defaults.
# PHASE2_VALIDATION_HOUSEHOLD_ID=11111111-1111-4111-8111-111111111111
# PHASE2_VALIDATION_APPROVED_PHONE_E164=+919999888877
# PHASE2_VALIDATION_APPROVED_DISPLAY_NAME=Phase 2 validated participant
# PHASE2_VALIDATION_APPROVED_MEMBER_ID=33333333-3333-4333-8333-333333333333
# PHASE2_VALIDATION_REJECTED_PHONE_E164=+919888777766
# PHASE2_VALIDATION_OWNER_ACCESS_TOKEN=replace-with-owner-session-jwt
