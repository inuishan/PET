# Runtime contract for the analytics-generate function and Phase 3 live validation.
# No ANALYTICS_GENERATE_URL override is required in the normal Phase 3 path.
# The validator derives /functions/v1/analytics-generate from SUPABASE_URL.
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
ANALYTICS_PIPELINE_SHARED_SECRET=replace-with-analytics-pipeline-shared-secret
# Optional: prefer a real authenticated household-member token for read validation.
# Keep this token server-side only. Never place it in the mobile env file.
# PHASE3_VALIDATION_READ_ACCESS_TOKEN=replace-with-authenticated-access-token
